# AI Receptionist System - Environment Variables
# Copy this file to .env and fill in your API keys and credentials

# OpenAI API Key (REQUIRED)
# Get your key from: https://platform.openai.com/account/api-keys
# Used for GPT-4o, Whisper, and TTS
OPENAI_API_KEY=sk-your-api-key-here

# Email Configuration (OPTIONAL)
# For Gmail: Use an app-specific password (not your regular password)
# See: https://support.google.com/accounts/answer/185833
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password

# Optional: Override config.yaml values via environment
# Uncomment and customize as needed:
# RECEPTIONIST_OFFICE_NAME=My Company
# RECEPTIONIST_OFFICE_ADDRESS=123 Main St, City
# RECEPTIONIST_TTS_VOICE=onyx
# RECEPTIONIST_CAMERA_INDEX=1
# RECEPTIONIST_GUI_FULLSCREEN=true
